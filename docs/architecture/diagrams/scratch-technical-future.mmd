%% =========================
%% Future Technical Architecture (Selective Microservices, Minimal High-Load)
%% =========================

%% =========================================================
%% CONSTRAINTS (EXPLICIT, BY DESIGN)
%% =========================================================
%% - Single Edge Load Balancer
%% - Single HTTP Ingress (no service mesh)
%% - Single Postgres primary + one read replica
%% - No sharding
%% - No distributed transactions
%% - Selective service extraction only
flowchart TB

%% =========================================================
%% CLIENTS / ENTRY
%% =========================================================

Client["Web / API Clients"]
Client:::clients

%% =========================================================
%% EDGE / TRAFFIC MANAGEMENT
%% =========================================================

EdgeLB["Edge Load Balancer"]
Ingress["HTTP Ingress"]

EdgeLB@{ shape: stadium }
Ingress@{ shape: stadium }

EdgeLB:::infra
Ingress:::infra

Client --> EdgeLB --> Ingress

%% =========================================================
%% SECURITY / PLATFORM POLICY
%% =========================================================

RateLimit["Rate Limiting"]
JWT["JWT Validation"]

RateLimit@{ shape: hex }
JWT@{ shape: hex }

RateLimit:::sec
JWT:::sec

Ingress --> RateLimit --> JWT

%% =========================================================
%% TENANT RESOLUTION (EDGE-CONCERN)
%% =========================================================

TenantResolver["Tenant Identity Resolution"]
TenantResolver@{ shape: rounded }
TenantResolver:::app

JWT --> TenantResolver

%% =========================================================
%% REDIS (SHARED INFRA, MULTI-ROLE)
%% =========================================================

RedisInfra["Redis (Shared)"]
RedisInfra@{ shape: stadium }
RedisInfra:::infra

RedisCache["Cache<br>(HTTP / Domain / Tenant)"]
RedisCache@{ shape: h-cyl }
RedisCache:::persistence

RedisQueues["Queues (Jobs / Streams)"]
RedisQueues@{ shape: h-cyl }
RedisQueues:::persistence

RedisRate["Rate Limits / Sessions"]
RedisRate@{ shape: h-cyl }
RedisRate:::persistence

RedisInfra --- RedisCache
RedisInfra --- RedisQueues
RedisInfra --- RedisRate

RateLimit --> RedisRate
TenantResolver --> RedisCache

%% =========================================================
%% APPLICATION BOUNDARY – MODULAR MONOLITH
%% =========================================================

subgraph Monolith["Scratch API (Modular Monolith)"]
direction TB

  AppLayer["Application Layer<br>(Controllers / Use-cases)"]
  AppLayer@{ shape: rounded }
  AppLayer:::app

  %% -------------------------
  %% DOMAIN MODULES (IN-PROCESS)
  %% -------------------------

  TasksDomain["Tasks Domain"]
  TasksDomain@{ shape: trap-b }
  TasksDomain:::domain

  UsersDomain["Users Domain"]
  UsersDomain@{ shape: trap-b }
  UsersDomain:::domain

  TenancyDomain["Tenancy Domain"]
  TenancyDomain@{ shape: trap-b }
  TenancyDomain:::domain

  AuditDomain["Audit Domain"]
  AuditDomain@{ shape: trap-b }
  AuditDomain:::domain

  AppLayer --> TasksDomain
  AppLayer --> UsersDomain
  AppLayer --> TenancyDomain
  AppLayer --> AuditDomain
end

TenantResolver --> AppLayer

%% =========================================================
%% TENANCY – METADATA & DB SCOPING
%% =========================================================

TenantMetaDB["Tenant Metadata DB<br>(public.tenants)"]
TenantMetaDB@{ shape: cylinder }
TenantMetaDB:::persistence

TenantSchemaDB["Tenant Schemas<br>(Business Data)"]
TenantSchemaDB@{ shape: cylinder }
TenantSchemaDB:::persistence

TenancyDomain --> RedisCache
TenancyDomain --> TenantMetaDB
TenancyDomain --> TenantSchemaDB

%% =========================================================
%% PRIMARY DATABASE (NO SHARDING)
%% =========================================================

PostgresPrimary["Postgres Primary"]
PostgresPrimary@{ shape: cylinder }
PostgresPrimary:::persistence

PostgresReplica["Postgres Read Replica"]
PostgresReplica@{ shape: cylinder }
PostgresReplica:::persistence

TasksDomain --> PostgresPrimary
UsersDomain --> PostgresPrimary
AuditDomain --> PostgresPrimary

TasksDomain --> PostgresReplica
UsersDomain --> PostgresReplica

%% =========================================================
%% SELECTIVELY EXTRACTED SERVICES
%% =========================================================

%% -------------------------
%% NOTIFICATIONS SERVICE
%% -------------------------

subgraph NotificationsSvc["Notifications Service"]
direction TB
  NotifApp["App Layer"]
  NotifApp@{ shape: rounded }
  NotifApp:::app

  NotifDomain["Notifications Domain"]
  NotifDomain@{ shape: trap-b }
  NotifDomain:::domain

  NotifApp --> NotifDomain
end

AuditDomain --> RedisQueues
RedisQueues --> NotifApp

%% -------------------------
%% WORKERS SERVICE (CPU / IO ISOLATION)
%% -------------------------

subgraph WorkersSvc["Workers Service"]
direction TB
  WorkerApp["Worker App"]
  WorkerApp@{ shape: rounded }
  WorkerApp:::app

  WorkerDomain["Job Processing Domain"]
  WorkerDomain@{ shape: trap-b }
  WorkerDomain:::domain

  WorkerApp --> WorkerDomain
end

RedisQueues --> WorkerApp

%% -------------------------
%% AUTH SERVICE (OPTIONAL EXTRACTION)
%% -------------------------

subgraph AuthSvc["Auth Service (Optional)"]
direction TB
  AuthApp["Auth App"]
  AuthApp@{ shape: rounded }
  AuthApp:::app

  AuthDomain["Auth Domain"]
  AuthDomain@{ shape: trap-b }
  AuthDomain:::domain

  AuthApp --> AuthDomain
end

AuthDomain --> JWT

%% =========================================================
%% SEARCH (MINIMAL, ASYNC)
%% =========================================================

SearchIndex["Search Index<br>(Postgres FTS / Elastic)"]
SearchIndex@{ shape: cylinder }
SearchIndex:::persistence

WorkersSvc --> SearchIndex
AppLayer --> SearchIndex

%% =========================================================
%% OBSERVABILITY & ANALYTICS (NON-INTRUSIVE)
%% =========================================================

Observability["Logs / Metrics / Traces"]
Observability@{ shape: lean-r }
Observability:::observability

Analytics["Analytics / BI"]
Analytics@{ shape: lean-r }
Analytics:::observability

Monolith --> Observability
NotificationsSvc --> Observability
WorkersSvc --> Observability

AuditDomain --> Analytics

