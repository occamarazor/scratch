---
config:
  look: neo
  theme: redux-dark
  layout: dagre
---
flowchart TB
    Web["Web / Client Apps"]
    Gateway["HTTP Gateway"]
    Monolith["Modular Monolith<br>(NestJS)"]

    Tasks["Tasks Module"]
    Users["Users / Auth Module"]
    Notifications["Notifications Module"]
    Jobs["Background Jobs"]

    SQL["Primary SQL Store<br>(Postgres)"]
    Cache["Cache / Queues<br>(Redis)"]
    Search["Search Layer<br>(TBD)"]
    Observability["Logs / Metrics / Health<br>(TBD)"]
    Analytics["Analytics / Warehouse<br>(Event-driven)"]

    Web --> Gateway --> Monolith
    Monolith --> Tasks & Users & Notifications & Jobs
    Tasks --> SQL
    Users --> SQL
    Notifications --> SQL & Cache
    Jobs --> Cache
    Monolith --> Observability
    Monolith -.-> Search
    Monolith -.-> Analytics

    Monolith@{ shape: trap-b }
    Gateway@{ shape: stadium }
    Tasks@{ shape: rounded }
    Users@{ shape: rounded }
    Notifications@{ shape: rounded }
    Jobs@{ shape: h-cyl }
    SQL@{ shape: cyl }
    Cache@{ shape: cyl }
    Search@{ shape: cyl }
    Observability@{ shape: lean-r }
    Analytics@{ shape: lean-r }

    classDef clients fill:#ffe6e6,stroke:#d0021b,color:#424242;
    classDef app fill:#ffeacc,stroke:#ff6d00,color:#424242;
    classDef domain fill:#fff2cc,stroke:#f5a623,color:#424242;
    classDef persistence fill:#e6f7e6,stroke:#7ed321,color:#424242;
    classDef infra fill:#e6f0ff,stroke:#4a90e2,color:#424242;
    classDef sec fill:#ccd9ff,stroke:#003399,color:#424242;
    classDef observability fill:#f9e6ff,stroke:#9013fe,color:#424242;
    classDef future fill:#e6e6e6,stroke:#9b9b9b,color:#424242,stroke-dasharray: 5 5

    class Web clients
    class Monolith app
    class Tasks,Users,Notifications domain
    class SQL persistence
    class Gateway,Jobs,Cache,Search,Analytics,Observability future

