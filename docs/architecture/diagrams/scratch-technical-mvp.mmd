%% =========================
%% MVP Technical View — Phase 1
%% =========================
flowchart TB
    Client["REST Client"]

    subgraph Runtime["NestJS App (Runtime)"]
        App["Application Bootstrap"]
        Controllers["Controllers<br>(DTOs + Validation)"]
        Domain["Tasks Domain"]
        Config["Config Module<br>(Typed + Validation)"]

        Controllers --> Domain
        Config --> App
        App --> Controllers
    end

    DB[("Postgres")]
    Migrations[("TypeORM<br>Migrations")]

    DevTools["DX Tooling<br>(pnpm, VSCode, tests)"]
    Docker["Docker Compose"]

    Client --> Controllers
    Domain --> DB
    Migrations --> DB
    Docker --> DB
    DevTools -.-> App

    %% Shapes
    Client@{ shape: rect }
    App@{ shape: rounded }
    Controllers@{ shape: rounded }
    Domain@{ shape: trap-b }
    Config@{ shape: rounded }
    DB@{ shape: cyl }
    Migrations@{ shape: cyl }
    DevTools@{ shape: stadium }
    Docker@{ shape: stadium }

    %% Classes
    class Client clients
    class App,Controllers,Config app
    class Domain domain
    class DB,Migrations persistence
    class DevTools,Docker infra

    %% Palette (Authoritative)
    classDef clients fill:#ffe6e6,stroke:#d0021b,color:#424242;
    classDef app fill:#ffeacc,stroke:#ff6d00,color:#424242;
    classDef domain fill:#fff2cc,stroke:#f5a623,color:#424242;
    classDef persistence fill:#e6f7e6,stroke:#7ed321,color:#424242;
    classDef infra fill:#e6f0ff,stroke:#4a90e2,color:#424242;
