# Tasks API — REST client examples for Scratch (Task Tracker)
# Set base URL (change if your app runs on a different host/port)
# Generated a JWT token
# JWT_SECRET=secret USER_ID=user-1 TENANT_ID=tenant-1 node scripts/auth.generate.js

@baseUrl = http://localhost:3000

# 🔐 TODO: remove generated JWT & update secret after tests
@token1 = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1c2VyLTEiLCJ0ZW5hbnRJZCI6InRlbmFudC0xIiwiaWF0IjoxNzc0MTA4MzQzLCJleHAiOjE3NzY3MDAzNDN9.YxgS5OGx8Mb4gDg0SdQicBMRjXEwSt7YLaztpDS60l0
@token2 = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1c2VyLTIiLCJ0ZW5hbnRJZCI6InRlbmFudC0yIiwiaWF0IjoxNzc0MTA4MzY1LCJleHAiOjE3NzY3MDAzNjV9.SdK7y9eqKtFkr190Jokl5bK4c8DKO_M7AwFITbisT0U

# ❌ List user tasks (401, no token)
GET {{baseUrl}}/api/tasks
Accept: application/json

###
# ✅ List user tasks (derived from token)
GET {{baseUrl}}/api/tasks
Authorization: Bearer {{token1}}
Accept: application/json

###
# ✅ Create task
POST {{baseUrl}}/api/tasks
Authorization: Bearer {{token1}}
Content-Type: application/json

{
  "title": "Write project README",
  "description": "Draft README for Scratch app",
  "priority": 2,
  "dueAt": "2025-11-01T12:00:00.000Z"
}

###
# ❌ Invalid create
POST {{baseUrl}}/api/tasks
Authorization: Bearer {{token1}}
Content-Type: application/json

{
  "description": "Invalid payload",
  "status": "Invalid status",
  "priority": 999,
  "ownerId": "Fake owner",
  "tenantId": "Fake tenant",
  "dueAt": "Invalid date",
  "createdAt": "2025-11-01T12:00:00.000Z"
}

###
# ✅ Bulk update (current user tasks)
PATCH {{baseUrl}}/api/tasks
Authorization: Bearer {{token1}}
Content-Type: application/json

{
  "ids": [1, 2],
  "patch": {
    "status": "IN_PROGRESS",
    "priority": 4
  }
}

###
# ❌ Invalid bulk update
PATCH {{baseUrl}}/api/tasks
Authorization: Bearer {{token1}}
Content-Type: application/json

{
  "ids": [1, 2],
  "patch": {
    "status": "FAKE_STATUS",
    "priority": 999
  }
}

###
# ⚠️ Delete current user tasks
DELETE {{baseUrl}}/api/tasks
Authorization: Bearer {{token1}}

###
# ✅ Get single task (if owned)
GET {{baseUrl}}/api/tasks/1
Authorization: Bearer {{token1}}
Accept: application/json

###
# ✅ Update single task
PATCH {{baseUrl}}/api/tasks/1
Authorization: Bearer {{token1}}
Content-Type: application/json

{
  "status": "DONE",
  "priority": 0
}

###
# ❌ Invalid update (dueAt null)
PATCH {{baseUrl}}/api/tasks/1
Authorization: Bearer {{token1}}
Content-Type: application/json

{
  "dueAt": null
}

###
# ✅ Delete single task
DELETE {{baseUrl}}/api/tasks/1
Authorization: Bearer {{token1}}


# Experimental endpoints

###
# ✅ Create task RAW
POST {{baseUrl}}/api/tasks/raw
Authorization: Bearer {{token1}}
Content-Type: application/json

{
  "title": "Raw task title",
  "description": "Raw task description",
  "priority": 2,
  "dueAt": "2025-11-01T12:00:00.000Z"
}

###
# ❌ Deadlock simulation PART 1
POST {{baseUrl}}/api/tasks/deadlock
Authorization: Bearer {{token1}}
Content-Type: application/json

{
  "firstId": 1,
  "secondId": 2
}

###
# ❌ Deadlock simulation PART 2
POST {{baseUrl}}/api/tasks/deadlock
Authorization: Bearer {{token1}}
Content-Type: application/json

{
  "firstId": 2,
  "secondId": 1
}