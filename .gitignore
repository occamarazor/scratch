# Node modules and package manager stores
node_modules/
.pnpm-store/
.pnp.*

# Build / compiled output
dist/
build/

# TypeScript cache / artifacts
*.tsbuildinfo

# Coverage reports
/coverage

# Docker / local system
docker-compose.override.yml
.docker/

# Editor configs
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS
.DS_Store

# Logs
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environments (keep committed .env.dev)
.env
.env.local
*.env.local

# Compiled JS (keep only TS sources)
**/*.js
**/*.map
**/*.d.ts

# Compiled Migrations (keep only TS sources)
src/migrations/**/*.js

# Temp
.tmp/
.temp/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports
report.*.json
