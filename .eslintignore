# Node modules and package manager stores
node_modules/
.pnpm-store/
.pnp.*

# Build / compiled output
dist/
build/

# TypeScript cache / artifacts
*.tsbuildinfo

# Coverage reports
coverage/

# Docker / local system
docker-compose.override.yml
.docker/

# Editor configs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store

# Logs
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environments (.env.dev committed)
.env
.env.local
*.env.local

# Compiled JS (lint only TS sources)
**/*.js
**/*.map
**/*.d.ts

# Compiled Migrations (lint only TS sources)
src/migrations/**/*.js

# Tests output or temp folders
.tmp/
.temp/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
