{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "App: Install",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "App: Dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start:dev"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "App: Debug",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start:debug"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "App: Build",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$tsc"],
      "group": "build"
    },
    {
      "label": "App: Prod",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start:prod"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "App: Format",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "format"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "App: Lint",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "lint"],
      "problemMatcher": ["$eslint-stylish"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "App: Test",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "DB: Start",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "db:up"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "DB: Stop",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "db:down"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "DB: Log",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "db:logs"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": true
      },
      "problemMatcher": []
    },
    {
      "label": "DB: Seed",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "seed:run"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    {
      "label": "DB: Migrations - Generate",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "migrate:generate"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "DB: Migrations - Run",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "migrate:run"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "DB: Migrations - Revert",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "migrate:revert"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
