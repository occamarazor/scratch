{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install deps",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Start Dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start:dev"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Start Debug",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start:debug"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$tsc"],
      "group": "build"
    },
    {
      "label": "Start Prod",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start:prod"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "format"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "lint"],
      "problemMatcher": ["$eslint-stylish"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Start DB (docker-compose)",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "db:up"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Stop DB (docker-compose)",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "db:down"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Log DB (docker-compose)",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "db:logs"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": true
      },
      "problemMatcher": []
    },
    {
      "label": "Start Seed",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "seed:run"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    {
      "label": "pnpm: migrate:generate",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "migrate:generate"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "pnpm: migrate:run",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "migrate:run"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "pnpm: migrate:revert",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "migrate:revert"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
