{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "App: Install",
      "type": "shell",
      "command": "pnpm install",
      "problemMatcher": [],
      "detail": "Install project dependencies with pnpm",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "App: Dev",
      "type": "shell",
      "command": "pnpm start:dev",
      "isBackground": true,
      "problemMatcher": [],
      "detail": "Start NestJS in watch mode (dev)",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "App: Debug",
      "type": "shell",
      "command": "pnpm start:debug",
      "isBackground": true,
      "problemMatcher": [],
      "detail": "Start NestJS with Node inspector enabled for debugger attach",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "App: Build",
      "type": "shell",
      "command": "pnpm build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": ["$tsc"],
      "group": "build",
      "detail": "Compile TypeScript to the dist/ directory"
    },
    {
      "label": "App: Prod",
      "type": "shell",
      "command": "pnpm start:prod",
      "isBackground": true,
      "problemMatcher": [],
      "detail": "Run the production build from dist/",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "App: Format",
      "type": "shell",
      "command": "pnpm format",
      "problemMatcher": [],
      "detail": "Run Prettier to format source files",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "App: Lint",
      "type": "shell",
      "command": "pnpm lint",
      "problemMatcher": ["$eslint-stylish"],
      "detail": "Run ESLint and auto-fix",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "App: Test - Unit",
      "type": "shell",
      "command": "pnpm test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Run unit tests with Jest"
    },
    {
      "label": "App: Test - E2E",
      "type": "shell",
      "command": "pnpm test:e2e",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Run end-to-end tests (test/jest-e2e.json)"
    },
    {
      "label": "Docker: Up",
      "type": "shell",
      "command": "pnpm docker:up",
      "problemMatcher": [],
      "detail": "Start Docker Compose services (Postgres, etc.)",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Docker: Down",
      "type": "shell",
      "command": "pnpm docker:down",
      "problemMatcher": [],
      "detail": "Stop and remove Docker Compose services",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Docker: Reset",
      "type": "shell",
      "command": "pnpm docker:reset",
      "problemMatcher": [],
      "detail": "Destroy volumes and start Docker Compose fresh",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "DB: Migrate",
      "type": "shell",
      "command": "pnpm db:migrate",
      "problemMatcher": [],
      "detail": "Run TypeORM migrations against the configured DB",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "DB: Revert Last Migration",
      "type": "shell",
      "command": "pnpm db:revert",
      "problemMatcher": [],
      "detail": "Revert the last TypeORM migration",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    }
  ]
}
