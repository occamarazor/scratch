{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install deps",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "group": "build",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Start Dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start:dev"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Debug",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start:debug"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start Prod",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start:prod"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "format"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "lint"],
      "problemMatcher": ["$eslint-stylish"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test"],
      "problemMatcher": ["$jest-stare"], 
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
